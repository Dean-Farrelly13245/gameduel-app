<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:paddingLeft="16dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/card_border">

    <TextView
        android:id="@+id/txt_game_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/retro_yellow"
        android:fontFamily="@font/pressstart2p"
        android:paddingBottom="6dp"/>

    <TextView
        android:id="@+id/txt_game_genre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="7sp"
        android:paddingTop="2dp"
        android:textColor="@color/retro_blue"
        android:fontFamily="@font/pressstart2p"/>

    <TextView
        android:id="@+id/txt_game_platform"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="7sp"
        android:paddingTop="2dp"
        android:textColor="@color/retro_text_secondary"
        android:fontFamily="@font/pressstart2p"/>

</LinearLayout>
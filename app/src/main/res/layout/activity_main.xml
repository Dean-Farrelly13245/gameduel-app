<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/retro_bg">

    <FrameLayout
        android:id="@+id/content_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@color/retro_card"
        app:itemTextColor="@color/retro_blue"
        app:itemIconTint="@color/retro_blue"
        app:itemTextAppearanceActive="@style/RetroNavText"
        app:itemTextAppearanceInactive="@style/RetroNavText"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>
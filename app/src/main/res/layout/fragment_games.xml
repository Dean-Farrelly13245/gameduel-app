<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/retro_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/txt_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/games_title"
            android:textSize="18sp"
            android:textColor="@color/retro_yellow"
            android:fontFamily="@font/pressstart2p"/>

        <Button
            android:id="@+id/btn_add_game"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_game_button"
            android:textSize="10sp"
            android:backgroundTint="@color/retro_blue"
            android:textColor="@color/retro_bg"/>

    </LinearLayout>

    <EditText
        android:id="@+id/edit_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/search_games_hint"
        android:textColor="@color/white"
        android:textColorHint="@color/retro_text_secondary"
        android:backgroundTint="@color/retro_blue"
        android:inputType="text"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinner_sort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/retro_blue"
        android:popupBackground="@color/retro_card"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_games"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>